+    func handlePeripheralManagerDidReceiveWrite(_ peripheral: CBPeripheralManager, requests: [CBATTRequest]) {
+        for request in requests {
+            if let data = request.value {
+                let hexString = data.map { String(format: "%02x", $0) }.joined()
+                let serviceUUID = request.characteristic.service?.uuid.uuidString ?? ""
+                let charUUID = request.characteristic.uuid.uuidString
+                
+                // Update the characteristic value
+                if let mutableChar = request.characteristic as? CBMutableCharacteristic {
+                    mutableChar.value = data
+                }
+                
+                // Emit characteristicValueChanged so JS receives peripheral write data
+                if let emitter = MunimBluetoothEventEmitter.shared {
+                    emitter.emitCharacteristicValueChanged([
+                        "deviceId": "peripheral",
+                        "serviceUUID": serviceUUID,
+                        "characteristicUUID": charUUID,
+                        "value": hexString
+                    ])
+                    NSLog("[MunimBluetooth] Peripheral write received: %@ bytes on %@", String(data.count), charUUID)
+                }
+            }
+            
+            // Respond to the write request
+            peripheral.respond(to: request, withResult: .success)
+        }
+    }
